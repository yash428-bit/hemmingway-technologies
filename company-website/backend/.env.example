# ── Hemmingway Technologies — Mailer Backend (Resend) ────────────────────────
#
# Copy this file to .env and fill in your credentials.
# NEVER commit the actual .env file — it's git-ignored by default.
# ──────────────────────────────────────────────────────────────────────────────

# ── Resend API Key ────────────────────────────────────────────────────────────
# Get yours at https://resend.com/api-keys
# ──────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── From address ──────────────────────────────────────────────────────────────
# Must be a verified sender domain in your Resend account.
# During testing you can use:  onboarding@resend.dev  (Resend's sandbox address)
# Production example:          noreply@yourdomain.com
# ──────────────────────────────────────────────────────────────────────────────
FROM_EMAIL=onboarding@resend.dev

# ── Recipient email (where contact form submissions are delivered) ─────────────
RECIPIENT_EMAIL=your_inbox@example.com

# ── Newsletter signup (blog page) ───────────────────────────────────────────────
# Optional. Powers the "Stay Updated" subscribe form on /blog.
# Create an Audience at https://resend.com/audiences and paste its ID below.
# If left blank, the subscribe form will show an error instead of pretending to work.
RESEND_AUDIENCE_ID=

# ── Server port (defaults to 5000 if not set) ─────────────────────────────────
PORT=5000

# ── Allowed CORS origin (your frontend URL) ───────────────────────────────────
# Dev:        http://localhost:5173
# Production: https://manishmandia133.github.io
CORS_ORIGIN=http://localhost:5173
