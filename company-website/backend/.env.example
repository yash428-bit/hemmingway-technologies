# ── Hemmingway Technologies — Mailer Backend ──────────────────────────────────
#
# Copy this file to .env and fill in your credentials.
# NEVER commit the actual .env file — it's git-ignored by default.
# ──────────────────────────────────────────────────────────────────────────────

# ── Gmail credentials ─────────────────────────────────────────────────────────
# Use your Gmail address and an App Password (NOT your real Gmail password).
# How to get an App Password:
#   1. Enable 2-Step Verification on your Google Account →
#      https://myaccount.google.com/security
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Select "Mail" and your device, then click "Generate"
#   4. Copy the 16-character code and paste it below (no spaces)
# ──────────────────────────────────────────────────────────────────────────────
GMAIL_USER=manishmandia1576@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# ── Recipient email (where contact form submissions are delivered) ─────────────
RECIPIENT_EMAIL=manishmandia1576@gmail.com

# ── Server port (defaults to 5000 if not set) ─────────────────────────────────
PORT=5000

# ── Allowed CORS origin (your frontend URL) ───────────────────────────────────
# Dev:        http://localhost:5173
# Production: https://manishmandia133.github.io
CORS_ORIGIN=http://localhost:5173
