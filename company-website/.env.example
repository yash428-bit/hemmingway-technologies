#
# Copy this file to .env for local development.
# NEVER commit the actual .env file — it's git-ignored.
# ──────────────────────────────────────────────────────────────────────────────

# ── Mailer backend URL ────────────────────────────────────────────────────────
# Dev: leave blank — Vite's dev server proxies /api/* to http://localhost:5000.
# Prod: set this to your deployed backend's public URL (Render/Railway/Fly/etc),
# e.g. https://hemmingway-mailer.onrender.com  (no trailing slash)
VITE_API_URL=
